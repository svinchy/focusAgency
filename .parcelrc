{
  "extends": "@parcel/config-default",
  "transformers": {
    "*.woff2": [
      "@parcel/transformer-raw"
    ],
    "*.otf": [
      "@parcel/transformer-raw"
    ],
    "*.svg": [
      "@parcel/transformer-inline-string"
    ],
    "*.wasm": [
      "@parcel/transformer-wasm"
    ]
  },
  "reporters": [
    "...",
    "parcel-reporter-static-files-copy"
  ]
}
